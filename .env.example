# Environment Variables for Minimalist E-commerce

# API Configuration (Java Spring Backend)
REACT_APP_API_URL=http://localhost:8080/api

# Development Settings
NODE_ENV=development

# Optional: Database URL (for Spring backend)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/minimalist_ecommerce
# SPRING_DATASOURCE_USERNAME=username
# SPRING_DATASOURCE_PASSWORD=password

# Optional: JWT Secret (for Spring backend)
# JWT_SECRET=your-secret-key-here

# Optional: Payment Gateway Keys (for Spring backend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

