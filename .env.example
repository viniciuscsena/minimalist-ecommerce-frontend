# Environment Variables for Minimalist E-commerce

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Development Settings
NODE_ENV=development

# Optional: Database URL (for backend)
# DATABASE_URL=postgresql://username:password@localhost:5432/minimalist_ecommerce

# Optional: JWT Secret (for backend)
# JWT_SECRET=your-secret-key-here

# Optional: Payment Gateway Keys (for backend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

